<h1>Orders</h1>
<table>
  <% @orders.each do |order| %>
    <tr id="order_<%= order[:id] %>">
      <td><%= order[:id] %></td>
      <td><%= order[:status] %></td>
      <td>
        <form action="/orders/<%= order[:id] %>/ship" method="POST" data-turbo="true">
          <button type="submit">Ship</button>
        </form>
      </td>
    </tr>
  <% end %>
</table>